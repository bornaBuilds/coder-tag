{
  "icon": "media/icon.png",
  "name": "coder-tag",
  "displayName": "Coder Tag",
  "description": "Play a producer-tag-style sound after successful Git pushes.",
  "version": "0.0.2",
  "publisher": "bornaBuilds",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bornaBuilds/coder-tag.git"
  },
  "homepage": "https://github.com/bornaBuilds/coder-tag#readme",
  "bugs": {
    "url": "https://github.com/bornaBuilds/coder-tag/issues"
  },
  "keywords": [
    "git",
    "push",
    "audio",
    "sound",
    "producer tag",
    "source control"
  ],
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:coderTag.preview",
    "onCommand:coderTag.selectSound",
    "onCommand:coderTag.addSound",
    "onCommand:coderTag.removeSound",
    "onCommand:coderTag.toggleEnabled",
    "onCommand:coderTag.setVolume",
    "onCommand:coderTag.openSettings",
    "onCommand:coderTag.testPush",
    "onCommand:coderTag.showMenu"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "coderTag.preview",
        "title": "Coder Tag: Preview Producer Tag"
      },
      {
        "command": "coderTag.selectSound",
        "title": "Coder Tag: Select Producer Tag"
      },
      {
        "command": "coderTag.addSound",
        "title": "Coder Tag: Add Sound"
      },
      {
        "command": "coderTag.removeSound",
        "title": "Coder Tag: Remove Sound"
      },
      {
        "command": "coderTag.toggleEnabled",
        "title": "Coder Tag: Toggle Enabled"
      },
      {
        "command": "coderTag.setVolume",
        "title": "Coder Tag: Set Volume"
      },
      {
        "command": "coderTag.openSettings",
        "title": "Coder Tag: Open Settings"
      },
      {
        "command": "coderTag.testPush",
        "title": "Coder Tag: Test Push"
      },
      {
        "command": "coderTag.showMenu",
        "title": "Coder Tag: Open Menu"
      }
    ],
    "configuration": {
      "title": "Coder Tag",
      "properties": {
        "coderTag.enabled": {
          "type": "boolean",
          "default": true,
          "scope": "application",
          "order": 10,
          "description": "Play the selected producer tag after successful push events."
        },
        "coderTag.selectedSound": {
          "type": "string",
          "default": "builtin-demo-1",
          "scope": "application",
          "order": 20,
          "description": "The selected producer tag ID. Use the Coder Tag: Select Producer Tag command instead of editing this value directly."
        },
        "coderTag.volume": {
          "type": "number",
          "default": 1,
          "minimum": 0,
          "maximum": 1,
          "multipleOf": 0.05,
          "scope": "application",
          "order": 30,
          "description": "Playback volume from 0 (silent) to 1 (full volume)."
        },
        "coderTag.syncCountsAsPush": {
          "type": "boolean",
          "default": true,
          "scope": "application",
          "order": 40,
          "description": "Play the producer tag when using the Source Control Sync button or auto-sync (a pull followed by a push). Because VS Code runs a push on every sync, this may also play when a sync had nothing to push. Disable to play only on an explicit push."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "clean": "node scripts/clean.mjs",
    "build": "npm run clean && npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "generate-demo-sounds": "node scripts/generateDemoSounds.mjs",
    "pretest": "npm run build && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "@types/vscode": "^1.93.0",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.9.2",
    "eslint": "^10.5.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  }
}
