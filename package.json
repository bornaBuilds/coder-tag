{
  "name": "coder-tag",
  "displayName": "coder-tag",
  "description": "Play a producer tag drop on successful git push",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Coder Tag",
      "properties": {
        "coderTag.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable coder tags"
        },
        "coderTag.audioFile": {
          "type": "string",
          "default": "",
          "description": "The path to the audio file to play when a coder tag is triggered"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "@types/sound-play": "^1.1.3",
    "@types/vscode": "^1.93.0",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "eslint": "^10.5.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  },
  "dependencies": {
    "sound-play": "^1.1.0"
  }
}
